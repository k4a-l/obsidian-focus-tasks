{
	"name": "obsidian-focus-tasks",
	"version": "1.1.2",
	"description": "A personal task helper plugin to manage tasks in current active note and daily notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"tsc": "tsc -noEmit",
		"tsc:watch": "tsc -noEmit --watch",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json package.json && npm run check",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "biome lint --write",
		"format": "biome format --write && remark . --output",
		"check": "biome check --write  --diagnostic-level=warn",
		"ci": "biome ci --diagnostic-level=warn",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "kasahala",
	"url": "https://github.com/k4a-l/obsidian-current-task",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@cspell/eslint-plugin": "^10.0.1",
		"@types/node": "^25.9.3",
		"@types/semver": "^7.7.1",
		"@vitest/coverage-v8": "^4.1.9",
		"builtin-modules": "^5.2.0",
		"esbuild": "^0.28.1",
		"husky": "^9.1.7",
		"obsidian": "^1.13.1",
		"remark": "^15.0.1",
		"remark-cli": "^12.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"obsidian-daily-notes-interface": "^0.9.5"
	},
	"overrides": {
		"esbuild": "^0.28.1"
	},
	"remarkConfig": {
		"settings": {
			"bullet": "-"
		},
		"plugins": [
			"remark-preset-lint-recommended"
		]
	}
}
